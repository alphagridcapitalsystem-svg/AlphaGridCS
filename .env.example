# Supabase Configuration
# Get these values from your Supabase project settings:
# https://app.supabase.com/project/[YOUR-PROJECT-ID]/settings/api

# Public URL for your Supabase project (visible to client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public API key for Supabase Auth (visible to client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (MUST be kept secret - server-only)
# Used for admin operations that bypass RLS policies
# Never expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
